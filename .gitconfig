[user]
	name = Pedro Drago
	email = 93255861+PedroDrago@users.noreply.github.com
[init]
	defaultBranch = main
[color]
	ui = auto
[core]
	editor = vim
	autocrlf = input
[safe]
	directory = /mnt/share/vault
	directory = *
[push]
	autoSetupRemote = true
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
